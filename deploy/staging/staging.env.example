POSTGRES_DB=dudesign_staging
POSTGRES_USER=dudesign
POSTGRES_PASSWORD=change-me

API_PORT=4000
WEB_PORT=3001
ADMIN_PORT=3002

# Empty means same-origin API through Nginx.
# Set only the origin, for example https://api.example.com, when API is hosted separately.
# Do not include the /api path suffix here.
NEXT_PUBLIC_DUDESIGN_API_URL=
NEXT_PUBLIC_DUDESIGN_ADMIN_BASE_PATH=/admin

# Runtime provider:
# - mock: built-in DUDesign mock runtime.
# - babel-o: external BabeL-O-compatible runtime adapter service.
DUDESIGN_RUNTIME_PROVIDER=mock

# Required when DUDESIGN_RUNTIME_PROVIDER=babel-o.
# Point this to the DUDesign/BabeL-O runtime adapter base URL, not the raw Nexus
# server unless Nexus exposes the DUDesign runtime contract endpoints.
BABELO_BASE_URL=
BABELO_API_KEY=
BABELO_AUTH_HEADER=
BABELO_TIMEOUT_MS=
BABELO_STREAM_IDLE_TIMEOUT_MS=
BABELO_STREAM_RECONNECT_ATTEMPTS=
BABELO_CONTRACT_VERSION=

# Runtime adapter service. Enable with:
# docker compose --profile babel-o -f deploy/staging/docker-compose.yml --env-file deploy/staging/.env up -d --build
RUNTIME_ADAPTER_PORT=4100
RUNTIME_ADAPTER_STATE_FILE=/app/.dudesign/runtime-adapter/state.json

# Raw BabeL-O Nexus endpoint consumed by the DUDesign runtime adapter.
# Do not point DUDesign API directly at raw Nexus.
BABELO_NEXUS_BASE_URL=http://babel-o-nexus:3000
# Replace before production. Staging default is only for internal compose networking.
BABELO_NEXUS_API_KEY=dudesign-staging-babelo-key
BABELO_NEXUS_AUTH_HEADER=

# Raw BabeL-O Nexus service. Keep BabeL-O source outside DUDesign and point
# BABELO_NEXUS_CONTEXT to that checked-out/released source directory on server.
BABELO_NEXUS_CONTEXT=/home/ubuntu/deployments/babel-o/current
BABELO_NEXUS_DOCKERFILE=/tmp/dudesign-babelo-nexus.Dockerfile
BABELO_NEXUS_PORT=3300
BABELO_NEXUS_ALLOWED_TOOLS=Read,ListDir,Glob,Grep,Write,Edit
BABELO_NEXUS_EXECUTE_TIMEOUT_MS=600000
BABELO_NEXUS_MAX_CONCURRENT_EXECUTIONS=4
BABELO_NEXUS_CONFIG_FILE=
